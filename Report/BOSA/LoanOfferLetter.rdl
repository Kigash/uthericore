                  <TextRun>
                    <Value xml:space="preserve">
</Value>
                    <Style />
                  </TextRun>
                  <TextRun>
                    <Value>MODE OF PAYMENT</Value>
                    <Style>
                      <FontWeight>Bold</FontWeight>
                    </Style>
                  </TextRun>
                  <TextRun>
                    <Value> You will be required to pay using any of the accepted mode within the Sacco services Platform </Value>
                    <Style />
