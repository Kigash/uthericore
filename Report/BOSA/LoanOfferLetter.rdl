                    <Value xml:space="preserve">
</Value>
                    <Style />
                  </TextRun>
                  <TextRun>
                    <Value>FACILITY AMOUNT Kshs.</Value>
                    <Style>
                      <FontWeight>Bold</FontWeight>
                    </Style>
