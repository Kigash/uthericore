                </TextRuns>
                <Style />
              </Paragraph>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>for the said installment amount.</Value>
                    <Style />
                  </TextRun>
                </TextRuns>
                <Style />
              </Paragraph>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>
Read and Accepted
Sign _________________
</Value>
                    <Style />
                  </TextRun>
                  <TextRun>
                    <Value>TERMS AND CONDITIONS</Value>
                    <Style>
                      <FontWeight>Bold</FontWeight>
                    </Style>
                  </TextRun>
                  <TextRun>
                    <Value xml:space="preserve"> </Value>
                    <Style />
                  </TextRun>
                </TextRuns>
                <Style />
              </Paragraph>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>(a) Payment of 3% Appraisal fee on the loan amount subject to a minimum of Kshs. 500.00 on
execution of the letter of offer ( Kshs.</Value>
                    <Style />
                  </TextRun>
                  <TextRun>
                    <Value>=First(Fields!Approved_Amount.Value, "DataSet_Result")</Value>
