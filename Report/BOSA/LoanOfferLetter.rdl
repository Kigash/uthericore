                  </TextRun>
                  <TextRun>
                    <Value>PURPOSE</Value>
                    <Style>
                      <FontWeight>Bold</FontWeight>
                    </Style>
                  </TextRun>
                  <TextRun>
                    <Value xml:space="preserve"> </Value>
                    <Style />
                  </TextRun>
                  <TextRun>
