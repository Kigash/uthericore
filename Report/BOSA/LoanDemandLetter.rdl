                      <FontWeight>Bold</FontWeight>
                    </Style>
                  </TextRun>
                  <TextRun>
                    <Value>,</Value>
                    <Style>
                      <FontFamily>Segoe UI</FontFamily>
                      <FontSize>8pt</FontSize>
                      <FontWeight>Bold</FontWeight>
                    </Style>
                  </TextRun>
                </TextRuns>
                <Style />
              </Paragraph>
            </Paragraphs>
            <rd:DefaultName>Member_Name</rd:DefaultName>
            <Top>0.17639cm</Top>
            <Left>0.10266cm</Left>
            <Height>0.54736cm</Height>
            <Width>8.37376cm</Width>
            <Style>
              <Border>
                <Style>None</Style>
              </Border>
              <PaddingLeft>2pt</PaddingLeft>
              <PaddingRight>2pt</PaddingRight>
              <PaddingTop>2pt</PaddingTop>
              <PaddingBottom>2pt</PaddingBottom>
            </Style>
          </Textbox>
          <Textbox Name="Textbox4">
            <CanGrow>true</CanGrow>
            <KeepTogether>true</KeepTogether>
            <Paragraphs>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>We </Value>
                    <Style />
                  </TextRun>
                  <TextRun>
                    <Value>TEST SACCO</Value>
                    <Style>
                      <FontWeight>Bold</FontWeight>
                    </Style>
                  </TextRun>
                  <TextRun>
                    <Value> do hereby formally demand immediate repayment of the outstanding balance of KES </Value>
                    <Style />
                  </TextRun>
                  <TextRun>
                    <Value>=First(Fields!Outstanding_Balance.Value, "DataSet_Result")</Value>
                    <Style>
                      <Format>n2</Format>
                    </Style>
                  </TextRun>
                  <TextRun>
                    <Value> the amount due and owing to the Sacco from you as at .</Value>
                    <Style />
                  </TextRun>
                </TextRuns>
                <Style />
              </Paragraph>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value />
                    <Style />
                  </TextRun>
                </TextRuns>
                <Style />
              </Paragraph>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>Please note that your total liability of KES </Value>
                    <Style />
                  </TextRun>
                  <TextRun>
                    <Value>=First(Fields!TotalArrears.Value, "DataSet_Result")</Value>
                    <Style>
                      <Format>n2</Format>
                    </Style>
                  </TextRun>
                  <TextRun>
                    <Value> continues to accrue default interest at the rate of  per annum, over and above the normal interest rate, compounded with monthly interests until payment in full.</Value>
                    <Style />
                  </TextRun>
                </TextRuns>
                <Style />
              </Paragraph>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value />
                    <Style />
                  </TextRun>
                </TextRuns>
                <Style />
              </Paragraph>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>Please note that failure to comply with this demand and pay the Sacco the said sum of KES </Value>
                    <Style />
                  </TextRun>
                  <TextRun>
                    <Value>=First(Fields!TotalArrears.Value, "DataSet_Result")</Value>
                    <Style>
                      <Format>n2</Format>
                    </Style>
                  </TextRun>
                  <TextRun>
                    <Value> within the </Value>
                    <Style />
                  </TextRun>
                  <TextRun>
                    <Value>NEXT</Value>
                    <Style>
                      <FontWeight>Bold</FontWeight>
                    </Style>
                  </TextRun>
                  <TextRun>
                    <Value xml:space="preserve"> </Value>
                    <Style />
                  </TextRun>
                  <TextRun>
                    <Value>FOURTEEN (14) DAYS</Value>
                    <Style>
                      <FontWeight>Bold</FontWeight>
                    </Style>
                  </TextRun>
                  <TextRun>
                    <Value> from the date hereof will result in action being taken against you to recover the said outstanding amount including the filing of legal proceedings in a court of law against you at your own peril as to costs and other incidentals and without further reference to you whatsoever.</Value>
                    <Style />
                  </TextRun>
                </TextRuns>
                <Style />
              </Paragraph>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value />
                    <Style />
                  </TextRun>
                </TextRuns>
                <Style />
              </Paragraph>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>TAKE NOTICE</Value>
                    <Style>
                      <FontWeight>Bold</FontWeight>
                    </Style>
                  </TextRun>
                  <TextRun>
                    <Value> that unless The Sacco receives the said sum of </Value>
                    <Style />
                  </TextRun>
                  <TextRun>
                    <Value>KES </Value>
                    <Style>
                      <FontWeight>Bold</FontWeight>
                    </Style>
                  </TextRun>
                  <TextRun>
                    <Value>=First(Fields!TotalArrears.Value, "DataSet_Result")</Value>
                    <Style>
                      <FontWeight>Bold</FontWeight>
                      <Format>n2</Format>
                    </Style>
                  </TextRun>
                  <TextRun>
                    <Value xml:space="preserve"> </Value>
                    <Style>
                      <FontWeight>Bold</FontWeight>
                    </Style>
                  </TextRun>
                  <TextRun>
                    <Value>in  the </Value>
                    <Style />
                  </TextRun>
                  <TextRun>
                    <Value>NEXT FOURTEEN (14) DAYS </Value>
                    <Style>
                      <FontWeight>Bold</FontWeight>
                    </Style>
                  </TextRun>
                  <TextRun>
                    <Value>from the date hereof, we will proceed with recovery efforts including forwarding your file to the Credit Reference Bureau (C.R.B) for default listing at your peril as to costs and other incidentals and without further reference to you whatsoever. Please note that this could have serious consequences on your ability to obtain or maintain credit facilities countrywide.</Value>
                    <Style />
                  </TextRun>
                </TextRuns>
                <Style />
              </Paragraph>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value />
                    <Style />
                  </TextRun>
                </TextRuns>
                <Style />
              </Paragraph>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>Yours faithfully,
Test Sacco Society Ltd
Name Mr/Ms. ________________________ Name Mr/Ms. __________________________
BRANCH MANAGER CREDIT SUPERVISOR</Value>
                    <Style />
                  </TextRun>
                </TextRuns>
                <Style />
              </Paragraph>
            </Paragraphs>
